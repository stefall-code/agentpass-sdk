# ═══════════════════════════════════════════════════════════════
# AgentPass v2.4 — Environment Variables
# Copy this file to .env and fill in your values
# ═══════════════════════════════════════════════════════════════

# ── Database ──────────────────────────────────────────────────
# SQLite (default, zero-config):
DATABASE_URL=sqlite:///./agent_iam.db
# PostgreSQL (production):
# DATABASE_URL=postgresql://user:password@localhost:5432/agent_iam

# ── JWT ───────────────────────────────────────────────────────
# Secret key for signing JWT tokens — CHANGE IN PRODUCTION
JWT_SECRET=dev-secret-change-me

# ── Bcrypt ────────────────────────────────────────────────────
# Rounds for password hashing. Demo: 4 (fast), Production: >=12
BCRYPT_ROUNDS=12

# ── CORS ──────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=http://127.0.0.1:8000,http://localhost:3000

# ── Server ────────────────────────────────────────────────────
HOST=127.0.0.1
PORT=8000

# ── Ngrok (Public Testing) ────────────────────────────────────
# Set your ngrok authtoken to enable public URL
# NGROK_AUTHTOKEN=your_ngrok_token_here

# ── Feishu Integration ────────────────────────────────────────
# App credentials (from Feishu Developer Console)
# FEISHU_APP_ID=cli_xxxxx
# FEISHU_APP_SECRET=xxxxx
# FEISHU_VERIFICATION_TOKEN=xxxxx
# FEISHU_ENCRYPT_KEY=xxxxx

# Public URL for Feishu webhook (if not using ngrok)
# FEISHU_PUBLIC_URL=https://your-domain.com

# Webhook URL for sending approval cards to Feishu group
# FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/xxxxx

# ── IAM Gateway ───────────────────────────────────────────────
# Base URL for IAM delegate API (default: http://127.0.0.1:8000/api/delegate)
# IAM_BASE_URL=http://127.0.0.1:8000/api/delegate

# ── Approval Callback ────────────────────────────────────────
# Base URL for Feishu approval callback buttons
# APPROVAL_CALLBACK_BASE_URL=http://your-public-url

# ── HitL Approval ─────────────────────────────────────────────
# Minutes before a pending approval auto-times-out
APPROVAL_TIMEOUT_MINUTES=10
